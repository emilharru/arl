{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eld-nas.local/schemas/directive.schema.json",
  "title": "ELD-NAS Directive (Ultra Minimal)",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "cycle_id",
    "project_id",
    "jobs"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "cycle_id": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "created_by": {
      "type": "string",
      "const": "director"
    },
    "created_at": {
      "type": "string"
    },
    "ensemble_architecture_policy": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "decision_rationale": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "proposal_mode": {
      "type": "string",
      "enum": [
        "explore",
        "exploit",
        "ablation",
        "retry_after_failure"
      ]
    },
    "train_fraction": {
      "type": "number",
      "exclusiveMinimum": 0,
      "maximum": 1
    },
    "ensemble_validation_subset_fraction": {
      "type": "number",
      "exclusiveMinimum": 0,
      "maximum": 1
    },
    "jobs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "job_type",
          "target",
          "candidate"
        ],
        "properties": {
          "job_type": {
            "type": "string",
            "const": "train_expert"
          },
          "target": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "modality",
              "class_label"
            ]
          },
          "candidate": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "candidate_id"
            ]
          }
        }
      }
    }
  }
}
