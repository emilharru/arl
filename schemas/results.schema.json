{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eld-nas.local/schemas/results.schema.json",
  "title": "ELD-NAS Results (Ultra Minimal)",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "cycle_id",
    "project_id",
    "jobs"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "directive_id": {
      "type": "string"
    },
    "cycle_id": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "started_at": {
      "type": "string"
    },
    "finished_at": {
      "type": "string"
    },
    "overall_status": {
      "type": "string"
    },
    "jobs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "job_type"
        ],
        "properties": {
          "job_id": {
            "type": "string"
          },
          "job_type": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "target": {
            "type": "object"
          },
          "candidate": {
            "type": "object"
          },
          "metrics": {
            "type": "object"
          }
        }
      }
    },
    "ensemble_evaluation": {
      "type": "object",
      "properties": {
        "ran": {
          "type": "boolean"
        },
        "status": {
          "type": "string"
        },
        "subset_fraction": {
          "type": [
            "number",
            "null"
          ],
          "exclusiveMinimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
